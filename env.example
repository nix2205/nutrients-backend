# NutriLens Backend Environment Variables
# Copy this file, rename to .env, fill in your values
# On Render: add these in Dashboard → Environment → Add Environment Variable

# Which model to use
MODEL_NAME=efficientnet

# Path to model checkpoint (relative to app.py)
CKPT_PATH=model/efficientnet_best.pth

# Path to selected classes file (relative to app.py)
CLASS_PATH=model/selected_classes.txt

# Port (Render sets this automatically, leave as is)
PORT=5000
